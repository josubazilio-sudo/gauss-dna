# Bot Ouro H4 — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Telegram (mesmo bot e canal dos outros bots)
