# Bot H4 Cripto — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Telegram (mesmo bot e canal dos outros bots)
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_CHAT_ID=-100123456789

# Gestão de risco
CAPITAL_BRL=500        # sua banca em reais
BRL_RATE=5.60          # cotação do dólar
RISK_PCT=0.03          # risco por trade: 0.03 = 3%

# Porta do servidor (padrão: 3001)
PORT_H4=3001
