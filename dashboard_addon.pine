//════════════════════════════════════════════════════════════
// COLE ESTE BLOCO NO FINAL DA ESTRATÉGIA EXISTENTE
// GRADE DE INDICADORES — GAUSS+DNA STATUS DE ENTRADA
//════════════════════════════════════════════════════════════

// ── Indicadores adicionais ───────────────────────────────
rsiVal  = ta.rsi(close, 14)
_rsiH   = ta.highest(rsiVal, 14)
_rsiL   = ta.lowest(rsiVal, 14)
sRsiK   = ta.sma((_rsiH - _rsiL) > 0 ? (rsiVal - _rsiL) / (_rsiH - _rsiL) : 0.5, 3)

obvVal  = ta.obv
obvEma  = ta.ema(obvVal, 20)

_cRange  = math.max(high - low, syminfo.mintick)
_sSupPct = (high - math.max(open, close)) / _cRange
_sInfPct = (math.min(open, close) - low)  / _cRange

_stEsUp  = sRsiK > 0.80 and rsiVal > 58
_stEsDn  = sRsiK < 0.05 and rsiVal < 42
_exTopo  = _sSupPct > 0.40
_exFund  = _sInfPct > 0.40
_segL    = not _stEsUp and not _exTopo
_segS    = not _stEsDn and not _exFund

_volBest = math.max(volume, volume[1])
_volNF   = _volBest >= volMa * 0.80
_rvol    = volume / math.max(volMa, 1.0)
_volSec  = _rvol < 0.25

_ha2L    = haBull and haBull[1]
_ha2S    = haBear and haBear[1]
_emaL    = ema10 > ema21 and ema21 > ema50
_emaS    = ema10 < ema21 and ema21 < ema50

// ── Arrays paralelos (sem UDT) ───────────────────────────
var _gnm = array.new_string()
var _gvl = array.new_string()
var _gcL = array.new_bool()
var _gcS = array.new_bool()

if barstate.islast
    array.clear(_gnm)
    array.clear(_gvl)
    array.clear(_gcL)
    array.clear(_gcS)

    array.push(_gnm, "RSI zona  (L<60 | S>40)")
    array.push(_gvl, str.tostring(math.round(rsiVal, 1)))
    array.push(_gcL, rsiVal < 60)
    array.push(_gcS, rsiVal > 40)

    array.push(_gnm, "ADX forca (L>=14 | S>=18)")
    array.push(_gvl, str.tostring(math.round(adx, 1)))
    array.push(_gcL, adx >= adxMin)
    array.push(_gcS, adx >= adxMinShort)

    array.push(_gnm, "ADX subindo")
    array.push(_gvl, "")
    array.push(_gcL, adxNotDecaying)
    array.push(_gcS, adxNotDecaying)

    array.push(_gnm, "Nao lateralizado (>=15)")
    array.push(_gvl, "")
    array.push(_gcL, adx >= 15)
    array.push(_gcS, adx >= 15)

    array.push(_gnm, "HA  1 vela")
    array.push(_gvl, "")
    array.push(_gcL, haBull)
    array.push(_gcS, haBear)

    array.push(_gnm, "HA  2 velas consecutivas")
    array.push(_gvl, "")
    array.push(_gcL, _ha2L)
    array.push(_gcS, _ha2S)

    array.push(_gnm, "MACD direcao + HA")
    array.push(_gvl, str.tostring(math.round(histLine, 5)))
    array.push(_gcL, macdBull)
    array.push(_gcS, macdBear)

    array.push(_gnm, "Fluxo de volume")
    array.push(_gvl, "")
    array.push(_gcL, flowBull)
    array.push(_gcS, flowBear)

    array.push(_gnm, "EMAs alinhadas (10>21>50)")
    array.push(_gvl, "")
    array.push(_gcL, _emaL)
    array.push(_gcS, _emaS)

    array.push(_gnm, "Posicao vs EMA 200")
    array.push(_gvl, "")
    array.push(_gcL, close > ema200)
    array.push(_gcS, close < ema200)

    array.push(_gnm, "Volume >= 80% MA (2 velas)")
    array.push(_gvl, str.tostring(math.round(_rvol, 2)) + "x")
    array.push(_gcL, _volNF)
    array.push(_gcS, _volNF)

    array.push(_gnm, "RVOL >= 0.5x")
    array.push(_gvl, str.tostring(math.round(_rvol, 2)) + "x")
    array.push(_gcL, _rvol >= 0.50)
    array.push(_gcS, _rvol >= 0.50)

    array.push(_gnm, "Vol. nao secando")
    array.push(_gvl, "")
    array.push(_gcL, not _volSec)
    array.push(_gcS, not _volSec)

    array.push(_gnm, "StochRSI ok (<0.80 / >0.05)")
    array.push(_gvl, str.tostring(math.round(sRsiK, 2)))
    array.push(_gcL, not _stEsUp)
    array.push(_gcS, not _stEsDn)

    array.push(_gnm, "Seguro  exaustao topo/fund")
    array.push(_gvl, "")
    array.push(_gcL, _segL)
    array.push(_gcS, _segS)

    array.push(_gnm, "Nao extendido  (<2.5 ATR)")
    array.push(_gvl, str.tostring(math.round(distLong, 1)) + "a")
    array.push(_gcL, notExtendedLong)
    array.push(_gcS, notExtendedShort)

    array.push(_gnm, "OBV confirmado")
    array.push(_gvl, "")
    array.push(_gcL, obvVal > obvEma)
    array.push(_gcS, obvVal < obvEma)

    array.push(_gnm, "Sweep de liquidez")
    array.push(_gvl, "")
    array.push(_gcL, liqSweepLong)
    array.push(_gcS, liqSweepShort)

    array.push(_gnm, "Score  >= |40|")
    array.push(_gvl, str.tostring(scoreLong))
    array.push(_gcL, scoreLong  >= 40)
    array.push(_gcS, scoreShort <= -40)

    // ── Contar prontos ───────────────────────────────────
    _nR   = array.size(_gnm)
    _metL = 0
    _metS = 0
    for i = 0 to _nR - 1
        if array.get(_gcL, i)
            _metL += 1
        if array.get(_gcS, i)
            _metS += 1

    // ── Tabela ───────────────────────────────────────────
    _tbl = table.new(position.top_right, 4, _nR + 2,
         border_width = 1,
         border_color = color.new(color.gray, 58),
         frame_width  = 2,
         frame_color  = color.new(color.rgb(50, 110, 230), 35))

    _hBg = color.new(color.rgb(10, 18, 52), 0)
    table.cell(_tbl, 0, 0, "GAUSS+DNA  INDICADOR",
         bgcolor=_hBg, text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(_tbl, 1, 0, "VALOR",
         bgcolor=_hBg, text_color=color.silver, text_size=size.small)
    table.cell(_tbl, 2, 0, "LONG",
         bgcolor=_hBg, text_color=color.lime, text_size=size.small)
    table.cell(_tbl, 3, 0, "SHORT",
         bgcolor=_hBg, text_color=color.red, text_size=size.small)

    for i = 0 to _nR - 1
        _row = i + 1
        _aBg = i % 2 == 0
             ? color.new(color.rgb(10, 12, 28), 0)
             : color.new(color.rgb(18, 20, 42), 0)
        _bl  = array.get(_gcL, i)
        _bs  = array.get(_gcS, i)

        table.cell(_tbl, 0, _row, array.get(_gnm, i),
             bgcolor=_aBg, text_color=color.silver, text_size=size.tiny, text_halign=text.align_left)
        table.cell(_tbl, 1, _row, array.get(_gvl, i),
             bgcolor=_aBg, text_color=color.gray, text_size=size.tiny)
        table.cell(_tbl, 2, _row, _bl ? "+" : "-",
             bgcolor    = _bl ? color.new(color.green, 70) : color.new(color.red, 78),
             text_color = _bl ? color.lime : color.red,
             text_size  = size.small)
        table.cell(_tbl, 3, _row, _bs ? "+" : "-",
             bgcolor    = _bs ? color.new(color.green, 70) : color.new(color.red, 78),
             text_color = _bs ? color.lime : color.red,
             text_size  = size.small)

    // ── Rodape: contagem ─────────────────────────────────
    _fBg = color.new(color.rgb(10, 18, 52), 0)
    _pL  = str.tostring(_metL) + " / " + str.tostring(_nR)
    _pS  = str.tostring(_metS) + " / " + str.tostring(_nR)
    _cPL = _metL >= _nR - 2 ? color.lime
         : _metL >= int(_nR * 0.65) ? color.yellow
         : color.red
    _cPS = _metS >= _nR - 2 ? color.lime
         : _metS >= int(_nR * 0.65) ? color.yellow
         : color.red

    table.cell(_tbl, 0, _nR + 1, "PRONTOS",
         bgcolor=_fBg, text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(_tbl, 1, _nR + 1, "",
         bgcolor=_fBg, text_color=color.white, text_size=size.small)
    table.cell(_tbl, 2, _nR + 1, _pL,
         bgcolor=_fBg, text_color=_cPL, text_size=size.normal)
    table.cell(_tbl, 3, _nR + 1, _pS,
         bgcolor=_fBg, text_color=_cPS, text_size=size.normal)
