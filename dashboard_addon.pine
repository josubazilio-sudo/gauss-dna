//════════════════════════════════════════════════════════════
// COLE ESTE BLOCO NO FINAL DA ESTRATÉGIA EXISTENTE
// GRADE DE INDICADORES — GAUSS+DNA STATUS DE ENTRADA
//════════════════════════════════════════════════════════════

// ── Indicadores adicionais (escopo global) ────────────────
_d_rsi  = ta.rsi(close, 14)
_d_rsiH = ta.highest(_d_rsi, 14)
_d_rsiL = ta.lowest (_d_rsi, 14)
_d_sRsi = ta.sma((_d_rsiH - _d_rsiL) > 0
     ? (_d_rsi - _d_rsiL) / (_d_rsiH - _d_rsiL) : 0.5, 3)
_d_obv  = ta.obv
_d_obvM = ta.ema(_d_obv, 20)
_d_cr   = math.max(high - low, syminfo.mintick)
_d_ssup = (high - math.max(open, close)) / _d_cr
_d_sinf = (math.min(open, close) - low)  / _d_cr
_d_stU  = _d_sRsi > 0.80 and _d_rsi > 58
_d_stD  = _d_sRsi < 0.05 and _d_rsi < 42
_d_exT  = _d_ssup > 0.40
_d_exF  = _d_sinf > 0.40
_d_segL = not _d_stU and not _d_exT
_d_segS = not _d_stD and not _d_exF
_d_vb   = math.max(volume, volume[1])
_d_vNF  = _d_vb >= volMa * 0.80
_d_rv   = volume / math.max(volMa, 1.0)
_d_vSec = _d_rv < 0.25
_d_h2L  = haBull and haBull[1]
_d_h2S  = haBear and haBear[1]
_d_eL   = ema10 > ema21 and ema21 > ema50
_d_eS   = ema10 < ema21 and ema21 < ema50

// ── Funções auxiliares (escopo global) ───────────────────
_dBg(v) => v ? color.new(color.green, 70) : color.new(color.red, 78)
_dTx(v) => v ? color.lime : color.red
_dLb(v) => v ? "+" : "-"

// ── Dashboard — só na última barra ───────────────────────
if barstate.islast

    // Condições: b##L = Long, b##S = Short
    b01L = _d_rsi < 60;          b01S = _d_rsi > 40
    b02L = adx >= adxMin;        b02S = adx >= adxMinShort
    b03L = adxNotDecaying;       b03S = adxNotDecaying
    b04L = adx >= 15;            b04S = adx >= 15
    b05L = haBull;               b05S = haBear
    b06L = _d_h2L;               b06S = _d_h2S
    b07L = macdBull;             b07S = macdBear
    b08L = flowBull;             b08S = flowBear
    b09L = _d_eL;                b09S = _d_eS
    b10L = close > ema200;       b10S = close < ema200
    b11L = _d_vNF;               b11S = _d_vNF
    b12L = _d_rv  >= 0.50;       b12S = _d_rv  >= 0.50
    b13L = not _d_vSec;          b13S = not _d_vSec
    b14L = not _d_stU;           b14S = not _d_stD
    b15L = _d_segL;              b15S = _d_segS
    b16L = notExtendedLong;      b16S = notExtendedShort
    b17L = _d_obv > _d_obvM;     b17S = _d_obv < _d_obvM
    b18L = liqSweepLong;         b18S = liqSweepShort
    b19L = scoreLong  >= 40;     b19S = scoreShort <= -40

    // Contagem
    mL = (b01L?1:0)+(b02L?1:0)+(b03L?1:0)+(b04L?1:0)+(b05L?1:0)+
         (b06L?1:0)+(b07L?1:0)+(b08L?1:0)+(b09L?1:0)+(b10L?1:0)+
         (b11L?1:0)+(b12L?1:0)+(b13L?1:0)+(b14L?1:0)+(b15L?1:0)+
         (b16L?1:0)+(b17L?1:0)+(b18L?1:0)+(b19L?1:0)

    mS = (b01S?1:0)+(b02S?1:0)+(b03S?1:0)+(b04S?1:0)+(b05S?1:0)+
         (b06S?1:0)+(b07S?1:0)+(b08S?1:0)+(b09S?1:0)+(b10S?1:0)+
         (b11S?1:0)+(b12S?1:0)+(b13S?1:0)+(b14S?1:0)+(b15S?1:0)+
         (b16S?1:0)+(b17S?1:0)+(b18S?1:0)+(b19S?1:0)

    // Tabela 4 colunas × 21 linhas (1 header + 19 linhas + 1 rodapé)
    T = table.new(position.top_right, 4, 21,
         border_width=1, border_color=color.new(color.gray, 58),
         frame_width=2,  frame_color=color.new(color.rgb(50,110,230), 35))

    hB = color.new(color.rgb(10,18,52), 0)
    aB = color.new(color.rgb(10,12,28), 0)
    bB = color.new(color.rgb(18,20,42), 0)
    fB = color.new(color.rgb(10,18,52), 0)

    // Header
    table.cell(T,0,0,"GAUSS+DNA  INDICADOR",bgcolor=hB,text_color=color.white, text_size=size.small,text_halign=text.align_left)
    table.cell(T,1,0,"VALOR",               bgcolor=hB,text_color=color.silver,text_size=size.small)
    table.cell(T,2,0,"LONG",                bgcolor=hB,text_color=color.lime,  text_size=size.small)
    table.cell(T,3,0,"SHORT",               bgcolor=hB,text_color=color.red,   text_size=size.small)

    // Linhas de dados
    v01 = str.tostring(math.round(_d_rsi, 1))
    v02 = str.tostring(math.round(adx, 1))
    v07 = str.tostring(math.round(histLine, 5))
    v12 = str.tostring(math.round(_d_rv, 2)) + "x"
    v14 = str.tostring(math.round(_d_sRsi, 2))
    v16 = str.tostring(math.round(distLong, 1)) + "a"
    v19 = str.tostring(scoreLong)

    table.cell(T,0, 1,"RSI zona (L<60 | S>40)",   bgcolor=aB,text_color=color.silver,text_size=size.tiny,text_halign=text.align_left)
    table.cell(T,1, 1,v01,bgcolor=aB,text_color=color.gray,text_size=size.tiny)
    table.cell(T,2, 1,_dLb(b01L),bgcolor=_dBg(b01L),text_color=_dTx(b01L),text_size=size.small)
    table.cell(T,3, 1,_dLb(b01S),bgcolor=_dBg(b01S),text_color=_dTx(b01S),text_size=size.small)

    table.cell(T,0, 2,"ADX forca (L>=14 | S>=18)",bgcolor=bB,text_color=color.silver,text_size=size.tiny,text_halign=text.align_left)
    table.cell(T,1, 2,v02,bgcolor=bB,text_color=color.gray,text_size=size.tiny)
    table.cell(T,2, 2,_dLb(b02L),bgcolor=_dBg(b02L),text_color=_dTx(b02L),text_size=size.small)
    table.cell(T,3, 2,_dLb(b02S),bgcolor=_dBg(b02S),text_color=_dTx(b02S),text_size=size.small)

    table.cell(T,0, 3,"ADX subindo",              bgcolor=aB,text_color=color.silver,text_size=size.tiny,text_halign=text.align_left)
    table.cell(T,1, 3,"",                          bgcolor=aB,text_color=color.gray,  text_size=size.tiny)
    table.cell(T,2, 3,_dLb(b03L),bgcolor=_dBg(b03L),text_color=_dTx(b03L),text_size=size.small)
    table.cell(T,3, 3,_dLb(b03S),bgcolor=_dBg(b03S),text_color=_dTx(b03S),text_size=size.small)

    table.cell(T,0, 4,"Nao lateralizado (>=15)",  bgcolor=bB,text_color=color.silver,text_size=size.tiny,text_halign=text.align_left)
    table.cell(T,1, 4,"",                          bgcolor=bB,text_color=color.gray,  text_size=size.tiny)
    table.cell(T,2, 4,_dLb(b04L),bgcolor=_dBg(b04L),text_color=_dTx(b04L),text_size=size.small)
    table.cell(T,3, 4,_dLb(b04S),bgcolor=_dBg(b04S),text_color=_dTx(b04S),text_size=size.small)

    table.cell(T,0, 5,"HA  1 vela",               bgcolor=aB,text_color=color.silver,text_size=size.tiny,text_halign=text.align_left)
    table.cell(T,1, 5,"",                          bgcolor=aB,text_color=color.gray,  text_size=size.tiny)
    table.cell(T,2, 5,_dLb(b05L),bgcolor=_dBg(b05L),text_color=_dTx(b05L),text_size=size.small)
    table.cell(T,3, 5,_dLb(b05S),bgcolor=_dBg(b05S),text_color=_dTx(b05S),text_size=size.small)

    table.cell(T,0, 6,"HA  2 velas consecutivas", bgcolor=bB,text_color=color.silver,text_size=size.tiny,text_halign=text.align_left)
    table.cell(T,1, 6,"",                          bgcolor=bB,text_color=color.gray,  text_size=size.tiny)
    table.cell(T,2, 6,_dLb(b06L),bgcolor=_dBg(b06L),text_color=_dTx(b06L),text_size=size.small)
    table.cell(T,3, 6,_dLb(b06S),bgcolor=_dBg(b06S),text_color=_dTx(b06S),text_size=size.small)

    table.cell(T,0, 7,"MACD direcao + HA",        bgcolor=aB,text_color=color.silver,text_size=size.tiny,text_halign=text.align_left)
    table.cell(T,1, 7,v07,bgcolor=aB,text_color=color.gray,text_size=size.tiny)
    table.cell(T,2, 7,_dLb(b07L),bgcolor=_dBg(b07L),text_color=_dTx(b07L),text_size=size.small)
    table.cell(T,3, 7,_dLb(b07S),bgcolor=_dBg(b07S),text_color=_dTx(b07S),text_size=size.small)

    table.cell(T,0, 8,"Fluxo de volume",           bgcolor=bB,text_color=color.silver,text_size=size.tiny,text_halign=text.align_left)
    table.cell(T,1, 8,"",                          bgcolor=bB,text_color=color.gray,  text_size=size.tiny)
    table.cell(T,2, 8,_dLb(b08L),bgcolor=_dBg(b08L),text_color=_dTx(b08L),text_size=size.small)
    table.cell(T,3, 8,_dLb(b08S),bgcolor=_dBg(b08S),text_color=_dTx(b08S),text_size=size.small)

    table.cell(T,0, 9,"EMAs alinhadas (10>21>50)", bgcolor=aB,text_color=color.silver,text_size=size.tiny,text_halign=text.align_left)
    table.cell(T,1, 9,"",                          bgcolor=aB,text_color=color.gray,  text_size=size.tiny)
    table.cell(T,2, 9,_dLb(b09L),bgcolor=_dBg(b09L),text_color=_dTx(b09L),text_size=size.small)
    table.cell(T,3, 9,_dLb(b09S),bgcolor=_dBg(b09S),text_color=_dTx(b09S),text_size=size.small)

    table.cell(T,0,10,"Posicao vs EMA 200",        bgcolor=bB,text_color=color.silver,text_size=size.tiny,text_halign=text.align_left)
    table.cell(T,1,10,"",                          bgcolor=bB,text_color=color.gray,  text_size=size.tiny)
    table.cell(T,2,10,_dLb(b10L),bgcolor=_dBg(b10L),text_color=_dTx(b10L),text_size=size.small)
    table.cell(T,3,10,_dLb(b10S),bgcolor=_dBg(b10S),text_color=_dTx(b10S),text_size=size.small)

    table.cell(T,0,11,"Volume >= 80% MA (2 velas)",bgcolor=aB,text_color=color.silver,text_size=size.tiny,text_halign=text.align_left)
    table.cell(T,1,11,v12,bgcolor=aB,text_color=color.gray,text_size=size.tiny)
    table.cell(T,2,11,_dLb(b11L),bgcolor=_dBg(b11L),text_color=_dTx(b11L),text_size=size.small)
    table.cell(T,3,11,_dLb(b11S),bgcolor=_dBg(b11S),text_color=_dTx(b11S),text_size=size.small)

    table.cell(T,0,12,"RVOL >= 0.5x",             bgcolor=bB,text_color=color.silver,text_size=size.tiny,text_halign=text.align_left)
    table.cell(T,1,12,v12,bgcolor=bB,text_color=color.gray,text_size=size.tiny)
    table.cell(T,2,12,_dLb(b12L),bgcolor=_dBg(b12L),text_color=_dTx(b12L),text_size=size.small)
    table.cell(T,3,12,_dLb(b12S),bgcolor=_dBg(b12S),text_color=_dTx(b12S),text_size=size.small)

    table.cell(T,0,13,"Vol. nao secando",          bgcolor=aB,text_color=color.silver,text_size=size.tiny,text_halign=text.align_left)
    table.cell(T,1,13,"",                          bgcolor=aB,text_color=color.gray,  text_size=size.tiny)
    table.cell(T,2,13,_dLb(b13L),bgcolor=_dBg(b13L),text_color=_dTx(b13L),text_size=size.small)
    table.cell(T,3,13,_dLb(b13S),bgcolor=_dBg(b13S),text_color=_dTx(b13S),text_size=size.small)

    table.cell(T,0,14,"StochRSI ok (<0.80/>0.05)", bgcolor=bB,text_color=color.silver,text_size=size.tiny,text_halign=text.align_left)
    table.cell(T,1,14,v14,bgcolor=bB,text_color=color.gray,text_size=size.tiny)
    table.cell(T,2,14,_dLb(b14L),bgcolor=_dBg(b14L),text_color=_dTx(b14L),text_size=size.small)
    table.cell(T,3,14,_dLb(b14S),bgcolor=_dBg(b14S),text_color=_dTx(b14S),text_size=size.small)

    table.cell(T,0,15,"Seguro exaustao",           bgcolor=aB,text_color=color.silver,text_size=size.tiny,text_halign=text.align_left)
    table.cell(T,1,15,"",                          bgcolor=aB,text_color=color.gray,  text_size=size.tiny)
    table.cell(T,2,15,_dLb(b15L),bgcolor=_dBg(b15L),text_color=_dTx(b15L),text_size=size.small)
    table.cell(T,3,15,_dLb(b15S),bgcolor=_dBg(b15S),text_color=_dTx(b15S),text_size=size.small)

    table.cell(T,0,16,"Nao extendido (<2.5 ATR)",  bgcolor=bB,text_color=color.silver,text_size=size.tiny,text_halign=text.align_left)
    table.cell(T,1,16,v16,bgcolor=bB,text_color=color.gray,text_size=size.tiny)
    table.cell(T,2,16,_dLb(b16L),bgcolor=_dBg(b16L),text_color=_dTx(b16L),text_size=size.small)
    table.cell(T,3,16,_dLb(b16S),bgcolor=_dBg(b16S),text_color=_dTx(b16S),text_size=size.small)

    table.cell(T,0,17,"OBV confirmado",            bgcolor=aB,text_color=color.silver,text_size=size.tiny,text_halign=text.align_left)
    table.cell(T,1,17,"",                          bgcolor=aB,text_color=color.gray,  text_size=size.tiny)
    table.cell(T,2,17,_dLb(b17L),bgcolor=_dBg(b17L),text_color=_dTx(b17L),text_size=size.small)
    table.cell(T,3,17,_dLb(b17S),bgcolor=_dBg(b17S),text_color=_dTx(b17S),text_size=size.small)

    table.cell(T,0,18,"Sweep de liquidez",         bgcolor=bB,text_color=color.silver,text_size=size.tiny,text_halign=text.align_left)
    table.cell(T,1,18,"",                          bgcolor=bB,text_color=color.gray,  text_size=size.tiny)
    table.cell(T,2,18,_dLb(b18L),bgcolor=_dBg(b18L),text_color=_dTx(b18L),text_size=size.small)
    table.cell(T,3,18,_dLb(b18S),bgcolor=_dBg(b18S),text_color=_dTx(b18S),text_size=size.small)

    table.cell(T,0,19,"Score >= |40|",             bgcolor=aB,text_color=color.silver,text_size=size.tiny,text_halign=text.align_left)
    table.cell(T,1,19,v19,bgcolor=aB,text_color=color.gray,text_size=size.tiny)
    table.cell(T,2,19,_dLb(b19L),bgcolor=_dBg(b19L),text_color=_dTx(b19L),text_size=size.small)
    table.cell(T,3,19,_dLb(b19S),bgcolor=_dBg(b19S),text_color=_dTx(b19S),text_size=size.small)

    // Rodapé: contagem total
    pL  = str.tostring(mL) + " / 19"
    pS  = str.tostring(mS) + " / 19"
    cPL = mL >= 17 ? color.lime : mL >= 12 ? color.yellow : color.red
    cPS = mS >= 17 ? color.lime : mS >= 12 ? color.yellow : color.red

    table.cell(T,0,20,"PRONTOS",bgcolor=fB,text_color=color.white, text_size=size.small,text_halign=text.align_left)
    table.cell(T,1,20,"",       bgcolor=fB,text_color=color.white, text_size=size.small)
    table.cell(T,2,20,pL,       bgcolor=fB,text_color=cPL,         text_size=size.normal)
    table.cell(T,3,20,pS,       bgcolor=fB,text_color=cPS,         text_size=size.normal)
